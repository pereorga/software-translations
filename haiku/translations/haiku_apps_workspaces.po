msgstr "Mostra la pestanya de la finestra"

#: Workspaces
msgid "Auto-raise"
msgstr "Alçament automàtic"

#: Workspaces
msgid "Remove replicant"
msgstr "Suprimeix el replicant"

#: Workspaces
msgid "Live in the Deskbar"
msgstr "Viu a la barra d’escriptori"

#: Workspaces
msgid "Switch on mouse wheel"
msgstr "Activa la rodeta del ratolí"

#: System+name
msgid "Workspaces"
msgstr "Espais de treball"
